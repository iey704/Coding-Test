import sys
input = sys.stdin.readline

n, d = map(int, input().split())
p = list(map(int, input().split()))
s = sorted(p)

left = 0
max_len = 0

for right in range(n):
    # 지름이 d 초과하면 left를 옮긴다
    while s[right] - s[left] > d:
        left += 1
    
    # 현재 구간 길이로 최댓값 갱신
    max_len = max(max_len, right - left + 1)

# 제거해야 할 개미 수
print(n - max_len)